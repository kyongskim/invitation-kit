# Kakao JavaScript 키 (공개 키 — 클라이언트 번들 노출 OK).
# 발급: https://developers.kakao.com/console/app
# Admin/REST/Native 키는 절대 여기에 두지 말 것.
# 키 부재 시 카카오톡 공유 버튼은 자동으로 URL 복사 폴백으로 동작.
NEXT_PUBLIC_KAKAO_APP_KEY=

# Firebase Web SDK config (방명록 · Firestore 용, 6 필드 모두 공개 식별자).
# 발급: Firebase Console > 프로젝트 설정 > 내 앱 > 웹 앱 (</>) > SDK 설정 및 구성 > "구성".
# 보호는 Firestore 보안 규칙으로 — Admin SDK / Service Account 는 절대 여기에 두지 말 것.
# 자세한 운영 원칙은 .claude/rules/firebase.md 참조.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase App Check — reCAPTCHA v3 site key (방명록·RSVP 봇 스팸 방어).
# 발급: Firebase Console > App Check > Apps > 웹 앱 등록 (reCAPTCHA v3 선택).
# 미설정 시 App Check init 자동 skip — 코드는 그대로 동작 (방어 비활성).
# Console 에서 Firestore "Enforce" 토글 켜면 토큰 없는 요청은 차단됨.
# 자세한 결정 근거는 docs/adr/009-app-check-strategy.md.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# GitHub App OAuth — v2.0 editor 의 "GitHub 연결" 흐름 (Phase 3+).
# App 등록: https://github.com/settings/apps/new
#   Repository permissions: Contents: Read & write · Metadata: Read-only
#                           · Administration: Read & write (template generate 용)
#   Where can this GitHub App be installed: Any account
#   Callback URL: https://<your-domain>/api/github/oauth + http://localhost:3000/api/github/oauth
# `_CLIENT_ID` 는 클라이언트 번들 노출 OK (공개 식별자).
# `_CLIENT_SECRET` 은 서버 전용 — `NEXT_PUBLIC_` 절대 금지, OAuth callback
# route 에서만 사용 (token 교환 즉시 휘발, DB · cookie · log 0 회 접촉).
# 자세한 결정 근거는 docs/adr/011-github-oauth-and-api.md.
NEXT_PUBLIC_GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# 사이트 origin — postMessage targetOrigin 기준 (callback HTML 이 opener 에
# 토큰 전달 시 origin 검증). 미설정 시 callback 요청의 origin 자동 사용
# (localhost dev 환경 자동 동작). production 에서 명시 권장.
NEXT_PUBLIC_SITE_URL=

# Kakao REST API 키 — `npm run geocode` CLI 전용 (클라이언트 노출 X).
# 발급: Kakao Developer Console > 내 애플리케이션 > 앱 키 > REST API 키
# (JavaScript 키와 같은 앱 안에 있음, 4 종 키 중 하나).
# venue.address → 좌표 자동 조회 시에만 사용. 미설정 시 좌표 수동 입력.
KAKAO_REST_API_KEY=
